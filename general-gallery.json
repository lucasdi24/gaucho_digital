    {
      "id": "gg_css",
      "elType": "container",
      "isInner": false,
      "settings": {
        "content_width": "full",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true }
      },
      "elements": [
        {
          "id": "gg_css_w",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "html": "<style>\n/* ── SECTION SHOW/HIDE (tab nav) ── */\n.gal-section { display: none !important; }\n.gal-section.gal-section--active { display: flex !important; flex-direction: column; width: 100%; }\n\n/* ── NAV MOBILE: pills ── */\n.gal-nav-wrapper { width: 100%; }\n.gal-sidebar-title { display: none; }\n.gal-nav-bar {\n  display: flex; flex-direction: row; gap: 8px;\n  overflow-x: auto; padding-bottom: 2px;\n  scrollbar-width: none; -ms-overflow-style: none;\n}\n.gal-nav-bar::-webkit-scrollbar { display: none; }\n.gal-nav-item {\n  display: inline-flex; align-items: center; gap: 7px;\n  white-space: nowrap; flex-shrink: 0;\n  padding: 9px 18px; border-radius: 100px;\n  border: 1.5px solid rgba(5,77,139,0.18); background: #fff;\n  font-family: 'Bricolage Grotesque', sans-serif;\n  font-size: 0.84rem; font-weight: 500; color: rgba(5,77,139,0.55);\n  cursor: pointer; transition: all 0.22s ease;\n  -webkit-tap-highlight-color: transparent; outline: none;\n}\n.gal-nav-item:hover { border-color: #054D8B; color: #054D8B; }\n.gal-nav-item.active { background: #054D8B; border-color: #054D8B; color: #fff; }\n\n/* ── NAV DESKTOP: sidebar ── */\n@media (min-width: 900px) {\n  .gal-outer { flex-direction: row !important; align-items: flex-start !important; }\n  .gal-nav-wrapper { width: 210px; flex-shrink: 0; }\n  .gal-sidebar-title {\n    display: block;\n    font-family: 'Bricolage Grotesque', sans-serif;\n    font-size: 0.55rem; font-weight: 700;\n    letter-spacing: 0.25em; text-transform: uppercase;\n    color: rgba(5,77,139,0.3); padding: 10px 14px 6px; user-select: none;\n  }\n  .gal-sidebar-inner {\n    position: sticky; top: 110px; background: #fff;\n    border-radius: 20px; padding: 8px;\n    box-shadow: 0 2px 24px rgba(5,77,139,0.08), 0 0 0 1px rgba(5,77,139,0.05);\n  }\n  .gal-nav-bar { flex-direction: column; overflow-x: visible; gap: 2px; padding-bottom: 0; }\n  .gal-nav-item {\n    white-space: normal; flex-shrink: 1; width: 100%;\n    padding: 11px 14px; border-radius: 12px; border: none; background: none;\n    color: rgba(5,77,139,0.55); font-size: 0.88rem; text-align: left;\n  }\n  .gal-nav-item:hover { background: rgba(5,77,139,0.05); color: #054D8B; border: none; }\n  .gal-nav-item.active { background: #054D8B; color: #fff; border: none; }\n  .gal-content-area { flex: 1; min-width: 0; }\n}\n\n/* ── FILTER BAR (dentro de cada galería) ── */\n.gal-filter-bar {\n  display: flex; flex-direction: row; flex-wrap: wrap;\n  gap: 8px; margin-bottom: 20px;\n}\n.gal-filter-btn {\n  padding: 7px 16px; border-radius: 100px;\n  border: 1.5px solid rgba(5,77,139,0.15); background: #fff;\n  font-family: 'Bricolage Grotesque', sans-serif;\n  font-size: 0.78rem; font-weight: 500; color: rgba(5,77,139,0.5);\n  cursor: pointer; transition: all 0.18s ease;\n  -webkit-tap-highlight-color: transparent; outline: none;\n}\n.gal-filter-btn:hover { border-color: #054D8B; color: #054D8B; }\n.gal-filter-btn.active { background: #054D8B; border-color: #054D8B; color: #fff; }\n\n/* ── IMAGE GRID ── */\n.gal-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 8px;\n}\n@media (min-width: 640px) {\n  .gal-grid { grid-template-columns: repeat(3, 1fr); }\n}\n.gal-item {\n  overflow: hidden; border-radius: 10px; cursor: pointer;\n  transition: opacity 0.25s ease, transform 0.25s ease;\n}\n.gal-item img {\n  width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n.gal-item:hover img { transform: scale(1.04); }\n.gal-item.gal-hidden {\n  display: none;\n}\n</style>\n\n<script>\n(function(){\n  function initTabs(){\n    var btns = document.querySelectorAll('.gal-nav-item');\n    var sections = document.querySelectorAll('.gal-section');\n    if(!btns.length || !sections.length) return;\n    btns.forEach(function(btn){\n      btn.addEventListener('click', function(){\n        var target = this.dataset.target;\n        btns.forEach(function(b){ b.classList.remove('active'); });\n        sections.forEach(function(s){ s.classList.remove('gal-section--active'); });\n        this.classList.add('active');\n        var el = document.getElementById(target);\n        if(el){\n          el.classList.add('gal-section--active');\n          setTimeout(function(){\n            var top = el.getBoundingClientRect().top + window.scrollY - 130;\n            window.scrollTo({top: top, behavior: 'smooth'});\n          }, 10);\n        }\n      });\n    });\n  }\n\n  function initFilters(){\n    document.querySelectorAll('.gal-filter-bar').forEach(function(bar){\n      bar.addEventListener('click', function(e){\n        var btn = e.target.closest('.gal-filter-btn');\n        if(!btn) return;\n        var filter = btn.dataset.filter;\n        var grid = bar.nextElementSibling;\n        if(!grid || !grid.classList.contains('gal-grid')) return;\n        bar.querySelectorAll('.gal-filter-btn').forEach(function(b){ b.classList.remove('active'); });\n        btn.classList.add('active');\n        grid.querySelectorAll('.gal-item[data-filter]').forEach(function(item){\n          if(filter === 'all' || item.dataset.filter === filter){\n            item.classList.remove('gal-hidden');\n          } else {\n            item.classList.add('gal-hidden');\n          }\n        });\n      });\n    });\n  }\n\n  function init(){\n    initTabs();\n    initFilters();\n  }\n\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>"
          },
          "elements": []
        }
      ]
    },

